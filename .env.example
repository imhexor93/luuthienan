# ─── Sao chép file này thành .env.local và điền giá trị thực ─────────────────

# Tạo secret ngẫu nhiên:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=your-random-secret-here

# URL app (localhost khi dev, URL Vercel khi production)
NEXTAUTH_URL=http://localhost:3000

# ─── Mật khẩu cho từng user ───────────────────────────────────────────────────
# Username tương ứng xem trong lib/auth.ts
AUTH_PASSWORD_ADMIN=your-admin-password
AUTH_PASSWORD_MANAGER=your-manager-password
AUTH_PASSWORD_VIEWER=your-viewer-password
